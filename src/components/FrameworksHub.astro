---
const methodologies = [
  { label: 'Agile/Scrum', level: 95, icon: '⚡', desc: 'Sử dụng cho Cluster ERP để quản lý sprint và backlog.', project: 'Cluster ERP' },
  { label: 'Lean Six Sigma', level: 75, icon: '🎯', desc: 'Tối ưu hóa luồng dữ liệu cho Mean Reversion Bot.', project: 'Quant Bot' },
  { label: 'OKRs/KPIs', level: 90, icon: '📊', desc: 'Thiết lập mục tiêu đo lường cho toàn bộ hệ thống Hub.', project: 'All Projects' },
  { label: 'Waterfall', level: 80, icon: '🌊', desc: 'Áp dụng cho các giai đoạn thiết kế kiến trúc lõi.', project: 'Core System' }
];

const toolStack = [
  { category: 'Work Management', tools: ['Jira', 'Confluence', 'ClickUp', 'Notion'] },
  { category: 'Data & Analytics', tools: ['PowerBI', 'Looker Studio', 'Excel', 'Python'] },
  { category: 'Communication', tools: ['Slack', 'Teams', 'Discord', 'Notion'] }
];
---

<section id="frameworks-hub" class="w-full min-h-screen flex items-center bg-background/50 py-10 border-y border-border overflow-hidden relative">
  <!-- Dynamic Background Particles -->
  <div class="absolute inset-0 opacity-10 pointer-events-none">
    <div class="absolute top-1/4 left-10 w-2 h-2 bg-primary rounded-full animate-ping"></div>
    <div class="absolute bottom-1/3 right-20 w-1.5 h-1.5 bg-accent rounded-full animate-ping" style="animation-delay: 1s"></div>
  </div>

  <div class="max-w-[1600px] mx-auto px-6 md:px-10 w-full">
    <!-- Header -->
    <div class="mb-4 flex flex-col md:flex-row md:items-end justify-between gap-4 reveal">
      <div class="space-y-1">
        <h2 class="text-3xl font-bold tracking-tighter text-foreground uppercase leading-none">Governance_&_Tools</h2>
        <p class="text-[10px] text-muted font-mono uppercase tracking-[0.3em]">Management Standards & System Ecosystem</p>
      </div>
      <div class="flex gap-3">
        <div class="flex items-center gap-2 px-3 py-1 bg-success/5 border border-success/20 rounded-full">
          <span class="w-1 h-1 bg-success rounded-full"></span>
          <span class="text-[8px] font-mono text-success uppercase font-bold tracking-widest">ISO_Aligned</span>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-12 gap-5 h-[calc(100vh-260px)] min-h-[480px]">
      <!-- LEFT: Methodology Matrix -->
      <div class="col-span-12 lg:col-span-4 bg-card/20 border border-border/80 rounded-[2rem] glass-premium p-6 flex flex-col reveal">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-6 h-px bg-primary/80"></div>
          <h3 class="text-[9px] font-bold uppercase tracking-[0.3em] opacity-80">Methodology_Stack</h3>
        </div>
        <div class="flex-1 space-y-4 flex flex-col justify-center">
          {methodologies.map(m => (
            <div class="space-y-1.5 group cursor-help relative">
              <div class="flex justify-between items-center">
                <div class="flex items-center gap-2">
                  <span class="text-lg group-hover:scale-125 transition-transform duration-300">{m.icon}</span>
                  <span class="text-xs font-bold text-foreground/90 group-hover:text-primary transition-colors">{m.label}</span>
                </div>
                <div class="text-[9px] font-mono text-primary opacity-60">LVL_{m.level}</div>
              </div>
              <div class="h-1 w-full bg-foreground/10 rounded-full overflow-hidden p-[0.5px]">
                <div class="h-full bg-primary rounded-full relative group-hover:shadow-[0_0_10px_rgba(var(--primary-rgb),0.5)] transition-all duration-500" style={{ width: `${m.level}%` }}></div>
              </div>
              <!-- Tooltip: Methodology Context -->
              <div class="absolute left-full ml-4 top-0 w-48 p-3 bg-background/90 backdrop-blur-xl border border-primary/20 rounded-xl opacity-0 group-hover:opacity-100 pointer-events-none transition-all z-20 shadow-2xl">
                <p class="text-[9px] text-primary font-bold uppercase mb-1">Applied_In: {m.project}</p>
                <p class="text-[8px] text-muted leading-relaxed">{m.desc}</p>
              </div>
            </div>
          ))}
        </div>
        <div class="mt-4 p-3 bg-foreground/[0.04] border border-border/80 rounded-xl">
          <p class="text-[8px] font-mono text-muted leading-relaxed italic text-center">
            "Standardization is the foundation for continuous improvement."
          </p>
        </div>
      </div>

      <!-- CENTER: Tool Connectivity Graph -->
      <div class="col-span-12 lg:col-span-5 relative bg-card/20 border border-border/80 rounded-[2rem] glass-premium overflow-hidden p-6 flex flex-col reveal" style="animation-delay: 0.1s">
        <!-- Graph Identifier Box -->
        <div class="absolute top-6 left-6 z-20 pointer-events-none">
          <div class="px-3 py-1.5 bg-background/80 backdrop-blur-md border-l-2 border-primary rounded-r-lg shadow-xl">
            <div class="text-[7px] font-mono text-primary uppercase tracking-[0.2em] mb-0.5">Ecosystem_Mapping</div>
            <div class="text-[10px] font-black text-foreground uppercase tracking-tighter">TOOL_CONNECTIVITY_NETWORK_V2</div>
          </div>
        </div>

        <div class="flex items-center gap-3 mb-2">
          <div class="w-6 h-px bg-primary/80"></div>
          <h3 class="text-[9px] font-bold uppercase tracking-[0.3em] opacity-70">Ecosystem_Network</h3>
        </div>
        <div class="flex-1 relative flex items-center justify-center scale-90">
          <div class="relative w-full h-full flex items-center justify-center">
             <!-- Orbits -->
             <div class="absolute w-40 h-40 border border-primary/30 rounded-full animate-spin-slow"></div>
             <div class="absolute w-[240px] h-[240px] border border-accent/20 rounded-full animate-reverse-spin"></div>
             
             <!-- Center Hub -->
             <div class="z-10 w-20 h-20 bg-primary/20 border border-primary/40 rounded-full flex items-center justify-center backdrop-blur-3xl shadow-2xl shadow-primary/20 group hover:scale-110 transition-transform duration-500">
               <div class="text-center">
                 <span class="text-[6px] font-mono text-muted block uppercase mb-1">Central</span>
                 <span class="text-[8px] font-bold font-mono tracking-tighter">HUB_V1</span>
               </div>
             </div>

             <!-- Floating Tool Nodes -->
             {['Jira', 'PowerBI', 'Notion', 'Slack', 'Excel'].map((tool, i) => (
               <div class="absolute group cursor-pointer tool-node" data-tool={tool} style={{
                 transform: `rotate(${i * 72}deg) translate(110px) rotate(-${i * 72}deg)`,
               }}>
                 <div class="p-2.5 bg-card/90 border border-border/80 rounded-lg text-[9px] font-bold shadow-xl backdrop-blur-md group-hover:border-primary group-hover:bg-primary/10 transition-all duration-300 node-box">
                   {tool}
                 </div>
                 <div class="absolute top-1/2 left-1/2 w-24 h-[1.5px] bg-gradient-to-r from-primary/50 to-transparent -translate-y-1/2 -z-10 origin-left" style="transform: rotate(180deg)"></div>
               </div>
             ))}
          </div>
        </div>
        <div class="grid grid-cols-3 gap-2 mt-2 pt-2 border-t border-border/80">
          {['INTEGRATED', 'AUTOMATED', 'SCALABLE'].map(status => (
            <div class="text-center py-2 bg-foreground/[0.04] rounded-xl border border-border/80 hover:border-primary transition-colors group">
              <span class="text-[6px] font-mono text-muted uppercase block mb-1 group-hover:text-primary transition-colors">{status}</span>
              <span class="text-[8px] font-bold text-success opacity-90 uppercase">Verified</span>
            </div>
          ))}
        </div>
      </div>

      <!-- RIGHT: Specialized Stack -->
      <div class="col-span-12 lg:col-span-3 space-y-3 flex flex-col reveal" style="animation-delay: 0.2s">
        {toolStack.map((cat, idx) => (
          <div class="flex-1 bg-card/20 border border-border/80 rounded-[2.5rem] glass-premium p-4 flex flex-col justify-center overflow-hidden group">
            <div class="flex items-center gap-2 mb-2">
              <div class="w-1.5 h-1.5 bg-primary rounded-full"></div>
              <h4 class="text-[8px] font-mono text-primary uppercase tracking-[0.2em]">{cat.category}</h4>
            </div>
            <div class="flex flex-wrap gap-1.5">
              {cat.tools.map(tool => (
                <span class="px-2 py-1 bg-foreground/[0.05] border border-border/80 hover:border-primary hover:bg-primary/10 rounded-lg text-[8px] font-bold transition-all duration-300 cursor-pointer tool-trigger" data-tool={tool}>
                  {tool}
                </span>
              ))}
            </div>
          </div>
        ))}
        <!-- Exit Points CTA -->
        <div class="p-3 bg-primary/15 border border-primary/40 rounded-2xl flex flex-col items-center gap-1.5 text-center group hover:bg-primary/25 transition-all">
          <p class="text-[8px] font-mono font-bold uppercase">Ready_to_scale?</p>
          <a href="#connect" class="text-[8px] font-black uppercase tracking-[0.2em] bg-primary text-background px-3 py-1.5 rounded-lg hover:scale-105 transition-all">Hire_System_Architect →</a>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // Tool Highlight Interaction
  const triggers = document.querySelectorAll('.tool-trigger');
  const nodes = document.querySelectorAll('.tool-node');

  triggers.forEach(trigger => {
    trigger.addEventListener('click', () => {
      const toolName = trigger.getAttribute('data-tool');
      
      // Clear previous highlights
      nodes.forEach(node => {
        const box = node.querySelector('.node-box');
        box.classList.remove('border-primary', 'bg-primary/20', 'scale-125');
        box.classList.add('border-border/50', 'bg-card/80');
      });

      // Highlight matching node
      nodes.forEach(node => {
        if (node.getAttribute('data-tool') === toolName) {
          const box = node.querySelector('.node-box');
          box.classList.add('border-primary', 'bg-primary/20', 'scale-125');
          box.classList.remove('border-border/50', 'bg-card/80');
        }
      });
    });
  });
</script>

<style>
  .glass { backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); }
  @keyframes spin-slow { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
  @keyframes reverse-spin { from { transform: rotate(360deg); } to { transform: rotate(0deg); } }
  .animate-spin-slow { animation: spin-slow 20s linear infinite; }
  .animate-reverse-spin { animation: reverse-spin 30s linear infinite; }
</style>
