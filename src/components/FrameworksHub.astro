---
const methodologies = [
  { label: 'Agile/Scrum', level: 95, icon: '⚡' },
  { label: 'Waterfall', level: 80, icon: '🌊' },
  { label: 'Lean Six Sigma', level: 75, icon: '🎯' },
  { label: 'OKRs/KPIs', level: 90, icon: '📊' }
];

const toolStack = [
  { category: 'Work Management', tools: ['Jira', 'Confluence', 'ClickUp', 'Asana', 'Notion'] },
  { category: 'Data & Analytics', tools: ['PowerBI', 'Looker Studio', 'Excel Advanced', 'Python'] },
  { category: 'Communication', tools: ['Slack', 'Microsoft Teams', 'Discord'] }
];
---

<div class="frameworks-hub-section w-full bg-background/50 py-12 border-y border-border overflow-hidden">
  <div class="w-full px-4 md:px-6">
    <!-- Header -->
    <div class="mb-8 flex flex-col md:flex-row md:items-end justify-between gap-4">
      <div>
        <h2 class="text-3xl font-bold tracking-tighter text-foreground uppercase">Governance_&_Tools</h2>
        <p class="text-sm text-muted font-mono mt-2 uppercase tracking-widest">Global Management Standards & Ecosystem</p>
      </div>
      <div class="flex gap-2">
        <span class="px-3 py-1 bg-primary/10 border border-primary/20 text-primary text-[10px] font-mono rounded-full uppercase">ISO_Aligned</span>
        <span class="px-3 py-1 bg-success/10 border border-success/20 text-success text-[10px] font-mono rounded-full uppercase">Certified_Practitioner</span>
      </div>
    </div>

    <div class="grid grid-cols-12 gap-4 h-[700px] min-h-[600px]">
      <!-- LEFT: Methodology Matrix -->
      <div class="col-span-12 lg:col-span-4 bg-card/40 border border-border rounded-2xl glass p-6 flex flex-col">
        <h3 class="text-xs font-bold uppercase tracking-[0.2em] mb-8 opacity-70">Methodology_Frameworks</h3>
        <div class="flex-1 space-y-8">
          {methodologies.map(m => (
            <div class="space-y-3">
              <div class="flex justify-between items-center">
                <div class="flex items-center gap-3">
                  <span class="text-xl">{m.icon}</span>
                  <span class="text-sm font-bold text-foreground">{m.label}</span>
                </div>
                <span class="text-xs font-mono text-primary">{m.level}%</span>
              </div>
              <div class="h-2 w-full bg-foreground/5 rounded-full overflow-hidden">
                <div class="h-full bg-primary rounded-full relative" style={{ width: `${m.level}%` }}>
                  <div class="absolute inset-0 bg-gradient-to-r from-transparent to-white/20 animate-shimmer"></div>
                </div>
              </div>
            </div>
          ))}
        </div>
        <div class="mt-8 p-4 bg-primary/5 border border-primary/10 rounded-xl">
          <p class="text-[10px] font-mono text-muted leading-relaxed italic">
            "Standardization is the foundation for continuous improvement. Without standards, there can be no improvement." - Taiichi Ohno
          </p>
        </div>
      </div>

      <!-- CENTER: Tool Connectivity Graph (Simulated) -->
      <div class="col-span-12 lg:col-span-5 relative bg-card/40 border border-border rounded-2xl glass overflow-hidden p-6 flex flex-col">
        <h3 class="text-xs font-bold uppercase tracking-[0.2em] mb-4 opacity-70">Tool_Ecosystem_Network</h3>
        <div class="flex-1 relative flex items-center justify-center">
          <!-- Circular Network Layout -->
          <div class="relative w-full h-full flex items-center justify-center">
             <div class="absolute w-48 h-48 border border-primary/20 rounded-full animate-spin-slow"></div>
             <div class="absolute w-72 h-72 border border-accent/10 rounded-full animate-reverse-spin"></div>
             
             <!-- Center Hub -->
             <div class="z-10 w-24 h-24 bg-primary/20 border border-primary rounded-full flex items-center justify-center backdrop-blur-xl shadow-2xl shadow-primary/20 group hover:scale-110 transition-transform">
               <span class="text-[10px] font-bold font-mono">ECO_SYSTEM</span>
             </div>

             <!-- Floating Tools -->
             {['Jira', 'PowerBI', 'Notion', 'Slack', 'Excel'].map((tool, i) => (
               <div class="absolute p-3 bg-card border border-border rounded-xl text-[10px] font-bold shadow-lg animate-float" style={{
                 transform: `rotate(${i * 72}deg) translate(140px) rotate(-${i * 72}deg)`,
                 animationDelay: `${i * 0.5}s`
               }}>
                 {tool}
               </div>
             ))}
          </div>
        </div>
        <div class="grid grid-cols-3 gap-2 mt-4 pt-4 border-t border-border">
          {['INTEGRATED', 'AUTOMATED', 'SCALABLE'].map(status => (
            <div class="text-center py-2 bg-foreground/5 rounded border border-border/50">
              <span class="text-[8px] font-mono text-muted uppercase block">{status}</span>
              <span class="text-[10px] font-bold text-success">VERIFIED</span>
            </div>
          ))}
        </div>
      </div>

      <!-- RIGHT: Specialized Stack -->
      <div class="col-span-12 lg:col-span-3 space-y-4 flex flex-col">
        {toolStack.map(cat => (
          <div class="flex-1 bg-card/40 border border-border rounded-2xl glass p-5 flex flex-col">
            <h4 class="text-[10px] font-mono text-primary uppercase tracking-widest mb-4">{cat.category}</h4>
            <div class="flex flex-wrap gap-2">
              {cat.tools.map(tool => (
                <span class="px-3 py-1.5 bg-foreground/5 border border-border hover:border-primary/50 rounded-lg text-[10px] font-bold transition-all cursor-default">
                  {tool}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</div>

<style>
  .glass { backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); }
  @keyframes spin-slow { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
  @keyframes reverse-spin { from { transform: rotate(360deg); } to { transform: rotate(0deg); } }
  @keyframes float { 0%, 100% { transform: translateY(0) rotate(var(--rot)); } 50% { transform: translateY(-10px) rotate(var(--rot)); } }
  .animate-spin-slow { animation: spin-slow 20s linear infinite; }
  .animate-reverse-spin { animation: reverse-spin 30s linear infinite; }
  .animate-shimmer { animation: shimmer 2s infinite linear; background-size: 200% 100%; }
  @keyframes shimmer { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }
</style>
