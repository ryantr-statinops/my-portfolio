---
import Badge from "./ui/Badge.astro";

interface Props {
  project: {
    id: string;
    data: {
      title: string;
      description: string;
      date: string;
      category: string;
      impact: string;
      thumbnail: string;
      tags: string[];
      status: string;
    };
  };
}

const { project } = Astro.props;
console.log('Project ID:', project.id);
console.log('Project Data ID:', project.data.id);

const categoryMap: Record<string, string> = {
  "finance-quant": "Quant",
  "ops-automation": "Ops",
  "data-math": "Data",
  "system-ui": "System",
  "ai-implementation": "AI",
  "software-engineering": "Software",
};
---

<article 
  class="group relative flex flex-col bg-card border border-border rounded-sm overflow-hidden hover:border-accent/30 transition-all duration-500 hover:-translate-y-1 reveal shadow-sm"
  data-category={project.data.category}
>
  <!-- Thumbnail -->
  <div class="aspect-video overflow-hidden relative border-b border-border">
    <img 
      src={project.data.thumbnail} 
      alt={project.data.title} 
      class="w-full h-full object-cover grayscale opacity-60 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-700 group-hover:scale-105"
    />
    <div class="absolute top-3 left-3 flex gap-2">
      <Badge variant="accent">{categoryMap[project.data.category] || project.data.category}</Badge>
      {project.data.status === "In Progress" && <Badge variant="outline">WIP</Badge>}
    </div>
  </div>
  
  <!-- Content -->
  <div class="p-5 flex-1 flex flex-col space-y-4">
    <div class="space-y-2">
      <div class="flex justify-between items-center">
        <h3 class="text-lg font-bold text-foreground group-hover:text-accent transition-colors duration-300">
          {project.data.title}
        </h3>
        <span class="text-[10px] font-mono text-muted">{project.data.date.split('-')[0]}</span>
      </div>
      <p class="text-muted text-sm line-clamp-2 leading-relaxed font-medium">
        {project.data.description}
      </p>
    </div>

    <!-- Impact Metric -->
    <div class="pt-3 mt-auto border-t border-border">
      <div class="flex items-center gap-2 mb-1.5">
        <div class="w-1 h-1 bg-success rounded-full"></div>
        <span class="text-[9px] uppercase tracking-widest text-muted font-bold">Key Impact</span>
      </div>
      <p class="text-[11px] text-success font-bold tracking-tight">
        {project.data.impact}
      </p>
    </div>

    <div class="flex justify-between items-center pt-2">
      <div class="flex gap-1.5">
        {project.data.tags.slice(0, 2).map(tag => (
          <span class="text-[9px] text-muted opacity-50 font-mono">#{tag}</span>
        ))}
      </div>
      <a 
        href={`/projects/${project.id}`} 
        class="text-[10px] font-bold uppercase tracking-widest text-foreground hover:text-accent transition-colors"
      >
        View Case _
      </a>
    </div>
  </div>
</article>
