---
---

<footer id="connect" class="relative w-full min-h-screen flex flex-col bg-background border-t border-border overflow-hidden snap-start">
  <!-- Decorative Background Element -->
  <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-primary/5 rounded-full blur-[150px] -translate-y-1/2 translate-x-1/3 pointer-events-none"></div>

  <div class="flex-1 flex items-center justify-center py-12 px-8 md:px-12">
    <div class="max-w-7xl w-full mx-auto grid grid-cols-12 gap-10">
      <!-- Left: Contact Info -->
      <div class="col-span-12 lg:col-span-5 space-y-10 flex flex-col justify-center reveal">
        <div class="space-y-4">
          <h2 class="text-5xl md:text-6xl font-bold tracking-tighter text-foreground leading-[0.85] uppercase">
            Sẵn sàng <br /> <span class="text-primary italic">Kết nối.</span>
          </h2>
          <div class="flex items-center gap-3 py-1.5 px-4 bg-success/5 border border-success/20 rounded-full w-fit">
            <span class="w-1.5 h-1.5 bg-success rounded-full animate-pulse"></span>
            <span class="text-[9px] font-mono font-bold text-success uppercase tracking-widest">System Status: Online</span>
          </div>
        </div>

        <div class="space-y-6">
          <div class="group cursor-pointer">
            <p class="text-[9px] font-mono text-muted uppercase tracking-[0.3em] mb-1 opacity-60">Communication_Channel</p>
            <a href="mailto:trankhang2856@gmail.com" class="text-xl font-bold hover:text-primary transition-all duration-300">trankhang2856@gmail.com</a>
          </div>
          
          <div class="group cursor-pointer">
            <p class="text-[9px] font-mono text-muted uppercase tracking-[0.3em] mb-1 opacity-60">Global_Base</p>
            <p class="text-xl font-bold">Ho Chi Minh City, Vietnam</p>
          </div>
        </div>

        <div class="flex flex-wrap gap-3 pt-2">
          {[
            { label: 'LinkedIn', url: 'https://www.linkedin.com/in/ryan-tr/' },
            { label: 'GitHub', url: 'https://github.com/ryantr-statinops' },
            { label: 'Behance', url: '#' }
          ].map(social => (
            <a href={social.url} target="_blank" class="text-[10px] font-mono font-bold uppercase tracking-widest py-2.5 px-5 border border-border/50 rounded-xl hover:bg-primary hover:text-background hover:border-primary transition-all duration-500">
              {social.label}
            </a>
          ))}
        </div>
      </div>

      <!-- Right: Contact Form -->
      <div class="col-span-12 lg:col-span-7 flex items-center reveal" style="animation-delay: 0.1s">
        <div class="w-full p-8 md:p-10 bg-card/10 border border-border/40 rounded-[2rem] glass-premium relative overflow-hidden group">
          <div class="absolute top-0 right-0 w-32 h-32 bg-primary/5 blur-3xl -translate-y-1/2 translate-x-1/2 group-hover:bg-primary/10 transition-colors"></div>
          
          <form class="space-y-8 relative z-10">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
              <div class="space-y-2">
                <label class="text-[9px] font-mono text-muted uppercase tracking-widest ml-1">Identity_Name</label>
                <input type="text" placeholder="Full Name" class="w-full bg-transparent border-b border-border/30 py-3 focus:border-primary focus:outline-none transition-all placeholder:text-muted/20 font-medium text-base" />
              </div>
              <div class="space-y-2">
                <label class="text-[9px] font-mono text-muted uppercase tracking-widest ml-1">Identity_Email</label>
                <input type="email" placeholder="Email Address" class="w-full bg-transparent border-b border-border/30 py-3 focus:border-primary focus:outline-none transition-all placeholder:text-muted/20 font-medium text-base" />
              </div>
            </div>
            <div class="space-y-2">
              <label class="text-[9px] font-mono text-muted uppercase tracking-widest ml-1">Context_Inquiry</label>
              <textarea rows="2" placeholder="Describe your requirement..." class="w-full bg-transparent border-b border-border/30 py-3 focus:border-primary focus:outline-none transition-all placeholder:text-muted/20 font-medium text-base resize-none"></textarea>
            </div>
            <button type="submit" class="w-full py-5 bg-primary text-background font-bold uppercase tracking-[0.5em] text-xs rounded-xl hover:scale-[1.02] active:scale-95 transition-all shadow-xl shadow-primary/20 group relative overflow-hidden">
               <span class="relative z-10 font-black">Transmit_Signal</span>
               <div class="absolute inset-0 bg-white/30 -translate-x-full group-hover:translate-x-0 transition-transform duration-700 ease-out"></div>
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom Footer Credits -->
  <div class="w-full px-8 md:px-12 py-6 border-t border-border/30 bg-foreground/[0.01]">
    <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-6">
      <div class="flex items-center gap-4">
        <div class="w-9 h-9 rounded-full overflow-hidden bg-muted/10 p-1 border border-border/50">
          <img src="/images/avt.png" alt="Ryan Tran" class="w-full h-full object-cover rounded-full" />
        </div>
        <div>
          <p class="text-[9px] font-mono text-foreground font-bold uppercase tracking-widest leading-none mb-1">© 2026 Ryan Tran</p>
          <p class="text-[8px] font-mono text-muted uppercase tracking-tighter">Precision_Systems_Specialist</p>
        </div>
      </div>
      <div class="flex items-center gap-8">
        <div class="flex flex-col items-end">
          <p class="text-[8px] font-mono text-muted uppercase tracking-[0.2em] mb-1">Deployment: v4.2.0-Production</p>
          <p class="text-[8px] font-mono text-success uppercase font-bold">Protocol_Secure</p>
        </div>
        <button id="scroll-to-top" class="w-10 h-10 flex items-center justify-center rounded-full border border-border/50 hover:bg-primary hover:text-background hover:border-primary transition-all duration-300 group">
          <span class="text-lg group-hover:-translate-y-1 transition-transform">↑</span>
        </button>
      </div>
    </div>
  </div>
</footer>

<style>
  .glass-premium {
    background: rgba(255, 255, 255, 0.01);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    box-shadow: 0 10px 40px 0 rgba(0, 0, 0, 0.2);
  }
  input:focus, textarea:focus {
    padding-left: 8px;
  }
</style>

<script>
  const btn = document.getElementById('scroll-to-top');
  if (btn) {
    btn.onclick = () => window.scrollTo({ top: 0, behavior: 'smooth' });
  }
</script>
