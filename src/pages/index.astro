---
import MainLayout from "../layouts/MainLayout.astro";
import IntelligenceHub from "../components/IntelligenceHub.astro";
import FrameworksHub from "../components/FrameworksHub.astro";
import AboutMe from "../components/AboutMe.astro";
import ProjectCard from "../components/ProjectCard.astro";
import HeatmapBackground from "../components/interactive/HeatmapBackground.astro";
import { getCollection } from "astro:content";

const projects = await getCollection("projects");
---

<MainLayout title="Ryan Tran | Command Center">
  <!-- Hero Section -->
  <section class="min-h-screen flex items-center pt-20 pb-20 px-8 md:px-12 w-full relative overflow-hidden bg-background snap-start">
    <HeatmapBackground />
    
    <div class="relative z-10 max-w-5xl w-full">
      <div class="space-y-10">
        <div class="space-y-4 reveal">
          <div class="flex items-center gap-3">
            <span class="w-2 h-2 bg-primary rounded-full animate-pulse shadow-[0_0_10px_rgba(var(--primary-rgb),0.8)]"></span>
            <p class="text-[10px] font-mono uppercase tracking-[0.4em] text-primary">System_Initialization_Success</p>
          </div>
          <h1 class="text-6xl md:text-8xl font-bold leading-[0.9] tracking-tighter uppercase">
            SYSTEMS. <br />
            OPERATIONS. <br />
            <span class="text-gradient">INTELLIGENCE.</span>
          </h1>
          <p class="text-muted text-xl md:text-2xl max-w-2xl font-medium leading-relaxed">
            Not a portfolio. This is a <span class="text-foreground font-bold">Command Center</span> of an Applied Statistics student specializing in <span class="text-primary italic font-semibold">Quantitative Finance</span> and <span class="text-foreground">System Architecture</span>.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 reveal">
          {[
            { label: 'NETWORK_STATUS', val: 'STABLE', color: 'text-success' },
            { label: 'ACTIVE_NODES', val: '5 SECTORS', color: 'text-primary' },
            { label: 'CURRENT_FOCUS', val: 'QUANT & STARTUP OPS', color: 'text-accent' }
          ].map(stat => (
            <div class="p-4 bg-foreground/[0.03] border border-border rounded-xl glass flex flex-col gap-1">
              <span class="text-[9px] font-mono text-muted uppercase tracking-widest">{stat.label}</span>
              <span class={`text-sm font-bold font-mono ${stat.color}`}>[ {stat.val} ]</span>
            </div>
          ))}
        </div>

        <div class="flex flex-wrap gap-4 pt-6 reveal">
          <a href="#about-me" class="px-8 py-4 bg-primary text-background font-bold uppercase tracking-[0.2em] text-xs rounded transition-all hover:scale-[1.05] shadow-lg shadow-primary/20">
            [ EXECUTE_SYSTEM_SCAN ]
          </a>
          <a href="#intelligence-hub" class="px-8 py-4 bg-foreground/5 border border-border text-foreground font-bold uppercase tracking-[0.2em] text-xs rounded transition-all hover:bg-foreground hover:text-background">
            [ ACCESS_HUB ]
          </a>
        </div>
      </div>
    </div>

    <div class="absolute bottom-10 left-12 flex flex-col items-center gap-4 reveal">
      <div class="h-16 w-px bg-gradient-to-b from-primary to-transparent"></div>
      <span class="text-[9px] font-mono text-muted uppercase tracking-[0.3em] vertical-text">Scroll_to_Navigate</span>
    </div>
  </section>

  <!-- About Me Section -->
  <section id="about-me" class="min-h-screen flex items-center bg-background border-t border-border/30 snap-start">
    <AboutMe />
  </section>

  <!-- Intelligence Hub Section (3D Graph & Metrics) -->
  <section id="intelligence-hub" class="min-h-screen flex items-center bg-background border-t border-border/30 overflow-hidden snap-start">
    <div class="w-full">
      <IntelligenceHub />
    </div>
  </section>

  <!-- Project Showcase Section (Visual Cards) -->
  <section id="projects" class="min-h-screen flex items-center py-20 bg-background/50 border-y border-border px-8 md:px-12 reveal snap-start">
    <div class="max-w-7xl mx-auto w-full">
      <div class="flex flex-col md:flex-row justify-between items-end mb-12 gap-6">
        <div class="space-y-4">
          <div class="flex items-center gap-2">
            <div class="w-8 h-px bg-primary/50"></div>
            <span class="text-[10px] font-mono text-primary uppercase tracking-[0.4em]">Audit_Asset_Log</span>
          </div>
          <h2 class="text-5xl md:text-7xl font-bold tracking-tighter uppercase leading-none">PROJECT. <br/><span class="text-primary">REGISTRY_</span></h2>
        </div>
        <div class="flex items-center gap-3">
           <span class="px-4 py-2 bg-foreground/5 border border-border rounded text-[9px] font-mono text-muted uppercase tracking-widest">Index: BY_PRIORITY</span>
        </div>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {projects.sort((a, b) => b.data.priority - a.data.priority).slice(0, 6).map(project => (
          <ProjectCard project={project} />
        ))}
      </div>

      {projects.length > 3 && (
        <div class="mt-12 flex justify-center">
          <a href="/projects" class="text-[10px] font-mono text-muted hover:text-primary transition-colors uppercase tracking-[0.4em] border-b border-border hover:border-primary pb-1">
            [ VIEW_FULL_INVENTORY_{projects.length}_ASSETS ]
          </a>
        </div>
      )}
    </div>
  </section>


  <!-- Governance & Frameworks Hub Section -->
  <section id="frameworks-hub" class="min-h-screen flex items-center bg-background border-t border-border overflow-hidden snap-start">
    <FrameworksHub />
  </section>
</MainLayout>

<style>
  .text-gradient {
    background: linear-gradient(to right, #00f2ff, #0ea5e9, #93f8d8);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .vertical-text {
    writing-mode: vertical-rl;
  }
  .glass {
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }
</style>
