---
import { getCollection, render } from "astro:content";
import MainLayout from "../../layouts/MainLayout.astro";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<MainLayout title={entry.data.title} description={entry.data.description}>
  <article class="max-w-4xl mx-auto py-32 px-8">
    <header class="mb-16 space-y-6 border-b border-white/5 pb-12">
      <div class="flex items-center gap-4 text-xs font-bold uppercase tracking-widest text-primary">
        <span class="px-2 py-1 border border-primary/20 rounded">
          {entry.data.category.replace('-', ' ')}
        </span>
        <span class="text-muted">•</span>
        <span class="text-muted font-mono">{entry.data.date}</span>
      </div>
      
      <h1 class="text-4xl md:text-6xl font-bold leading-tight">
        {entry.data.title}
      </h1>
      
      <p class="text-xl text-muted leading-relaxed">
        {entry.data.description}
      </p>

      <div class="flex flex-wrap gap-3 pt-4">
        {entry.data.stack.map(item => (
          <span class="px-3 py-1 bg-white/5 rounded-full text-xs font-medium border border-white/5">
            {item}
          </span>
        ))}
      </div>
    </header>

    <div class="prose prose-invert prose-primary max-w-none 
      prose-headings:font-bold prose-headings:tracking-tight 
      prose-h2:text-primary prose-h2:text-2xl prose-h2:mt-12 prose-h2:mb-6
      prose-p:text-muted prose-p:leading-relaxed prose-p:mb-6
      prose-li:text-muted
      prose-code:text-primary prose-code:bg-primary/5 prose-code:px-1 prose-code:rounded
      prose-img:rounded-xl prose-img:border prose-img:border-white/5">
      <Content />
    </div>

    <div class="mt-20 pt-12 border-t border-white/5">
      <h3 class="text-xs uppercase tracking-widest text-muted font-bold mb-8">Links & Resources</h3>
      <div class="flex gap-4">
        {entry.data.github && (
          <a href={entry.data.github} target="_blank" class="px-6 py-3 bg-white/5 hover:bg-white/10 border border-white/10 rounded font-bold transition-all">
            GitHub Repo
          </a>
        )}
        {entry.data.demo && (
          <a href={entry.data.demo} target="_blank" class="px-6 py-3 bg-primary text-background hover:opacity-90 rounded font-bold transition-all">
            Live Demo
          </a>
        )}
      </div>
    </div>
  </article>
</MainLayout>

<style is:global>
  /* Fix for markdown content images */
  .prose img {
    width: 100%;
    margin-top: 2rem;
    margin-bottom: 2rem;
  }
</style>
